# ─────────────────────────────────────────────
# THE COZY CANVAS — Environment Variables
# Copy this file to .env.local and fill in all values.
# NEVER commit .env.local to version control.
# ─────────────────────────────────────────────

# MongoDB Atlas connection string
MONGODB_URI=mongodb+srv://everglow_db_user:oMn74a9RUkveYmX0@cozycanvas.frzenic.mongodb.net/?appName=CozyCanvas

# NextAuth
NEXTAUTH_URL=https://your-vercel-deployment.vercel.app
# Generate with: openssl rand -base64 32
NEXTAUTH_SECRET=your-secret-here

# SMTP email sending
SMTP_HOST=smtp.everglowlk.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=hello@everglow.events
SMTP_PASS=your-smtp-password
SMTP_FROM="EverGlow Events <hello@everglow.events>"

# Cloudinary (for payment receipt uploads)
CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-api-key
CLOUDINARY_API_SECRET=your-api-secret

# Public app URL (used in emails for ticket links)
NEXT_PUBLIC_APP_URL=https://your-vercel-deployment.vercel.app
